# vengine secrets — copy to `.env` (gitignored) and fill in.
# Only the server reads these; keys are NEVER sent to the browser.

# Primary: fal.ai aggregator — unlocks Nano Banana Pro, Seedream, Qwen, Z-Image, Flux.2
FAL_KEY=

# Optional providers (the matching fal/replicate/higgsfield models light up when set)
# REPLICATE_KEY=
# HIGGSFIELD_KEY=

# Optional: Claude intelligence layer (prompt-craft node / MCP), added in M5
# ANTHROPIC_API_KEY=

# Server port (default 5174)
# PORT=5174
